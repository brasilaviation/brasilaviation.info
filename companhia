<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Companhia | BrasilAviation</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { display: flex; flex-direction: column; min-height: 100vh; margin: 0; transition: background 0.3s; font-family: sans-serif; }
        .cia-header { width: 100%; padding: 40px 20px; text-align: center; color: white; box-sizing: border-box; }
        .bg-azul { background: linear-gradient(135deg, #00205b, #0093d1); }
        .bg-gol { background: linear-gradient(135deg, #ff5a00, #ff8a05); }
        .bg-latam { background: linear-gradient(135deg, #1b0088, #e8114b); }
        .cia-title { font-size: 28px; font-weight: bold; text-transform: uppercase; }
        .feed-container { padding: 15px; flex: 1; max-width: 1100px; margin: 0 auto; width: 100%; box-sizing: border-box; }
        .news-item { display: flex; gap: 15px; margin-bottom: 15px; cursor: pointer; border-bottom: 1px solid #eee; padding-bottom: 10px; align-items: center; text-decoration: none; color: inherit; }
        .news-photo img { width: 120px; height: 80px; object-fit: cover; border-radius: 8px; }
        .news-info h3 { font-size: 16px; margin: 0; line-height: 1.3; }
        body.dark-mode { background: #121212; color: #eee; }
        body.dark-mode .news-item { border-bottom-color: #333; }
    </style>
</head>
<body>

<div id="menu-placeholder"></div>
<div id="header-placeholder"></div>

<div id="cia-banner" class="cia-header"><div id="cia-nome" class="cia-title">Carregando...</div></div>
<main class="feed-container"><div id="news-feed-cia"></div></main>
<div id="footer-placeholder"></div>

<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/12.12.1/firebase-app.js";
    import { getFirestore, collection, getDocs, query, where, orderBy } from "https://www.gstatic.com/firebasejs/12.12.1/firebase-firestore.js";

    const firebaseConfig = { apiKey: "AIzaSyDm_UDs4KE7j8BuGdw9kClsSrKwxLWbt7g", authDomain: "braviation3.firebaseapp.app", projectId: "braviation3", storageBucket: "braviation3.firebasestorage.app", messagingSenderId: "979009087877", appId: "1:979009087877:web:490bdc36da545d56b87cec" };
    const app = initializeApp(firebaseConfig);
    const db = getFirestore(app);

    // Componentes e Cliques (Unificado)
    async function carregarComponentes() {
        const [h, f, m] = await Promise.all([
            fetch('/cabecalho.html').then(r => r.text()),
            fetch('/rodape.html').then(r => r.text()),
            fetch('/menu.html').then(r => r.text())
        ]);
        document.getElementById('header-placeholder').innerHTML = h;
        document.getElementById('footer-placeholder').innerHTML = f;
        document.getElementById('menu-placeholder').innerHTML = m;
        if (localStorage.getItem('dark-mode') === 'active') document.body.classList.add('dark-mode');
    }

    document.addEventListener('click', (e) => {
        const t = e.target;
        if (t.closest('#open-menu')) document.getElementById('side-menu')?.classList.add('active');
        if (t.closest('#close-menu')) document.getElementById('side-menu')?.classList.remove('active');
        if (t.closest('#btn-toggle-cat')) {
            document.getElementById('lista-cat')?.classList.toggle('active');
            document.getElementById('seta-cat')?.classList.toggle('rotate');
        }
        if (t.closest('#dark-toggle-header')) {
            document.body.classList.toggle('dark-mode');
            localStorage.setItem('dark-mode', document.body.classList.contains('dark-mode') ? 'active' : 'inactive');
        }
    });

    const params = new URLSearchParams(window.location.search);
    const ciaSlug = params.get('cia')?.toLowerCase();
    const configCia = { azul: { nome: "AZUL", classe: "bg-azul" }, gol: { nome: "GOL", classe: "bg-gol" }, latam: { nome: "LATAM", classe: "bg-latam" } };
    
    if (configCia[ciaSlug]) {
        const c = configCia[ciaSlug];
        document.getElementById('cia-banner').classList.add(c.classe);
        document.getElementById('cia-nome').innerText = c.nome;
        carregarNoticiasCia(c.nome);
    }

    async function carregarNoticiasCia(nomeFiltro) {
        // Busca todas para garantir que o filtro manual pegue variações de texto
        const q = query(collection(db, "noticias"), orderBy("data", "desc"));
        const snap = await getDocs(q);
        let html = "";
        
        snap.forEach(d => {
            const n = d.data();
            const catDoc = (n.cat || n.categoria || "").toUpperCase();
            // Verifica se a categoria da notícia bate com o filtro (ex: AZUL == AZUL)
            if (catDoc === nomeFiltro) {
                html += `
                <article class="news-item" onclick="window.location.href='/noticia?id=${d.id}'">
                    <div class="news-photo"><img src="${n.foto}"></div>
                    <div class="news-info"><h3>${n.titulo}</h3></div>
                </article>`;
            }
        });
        document.getElementById('news-feed-cia').innerHTML = html || "<p style='text-align:center; padding:20px;'>Nenhuma notícia da " + nomeFiltro + " encontrada.</p>";
    }

    carregarComponentes();
</script>
</body>
</html>
